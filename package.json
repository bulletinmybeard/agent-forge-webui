{
  "name": "agent-forge-webui",
  "version": "0.2.0",
  "description": "React SPA front-end for AgentForge — every mode, tool call, and connector in one chat UI",
  "type": "module",
  "license": "MIT",
  "author": "Robin Schulz",
  "homepage": "https://github.com/bulletinmybeard/agent-forge-webui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bulletinmybeard/agent-forge-webui.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "lint:fix:unsafe": "biome lint . --write --unsafe",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:fix:unsafe": "biome check --write --only=a11y/useButtonType --unsafe "
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.16"
  }
}
